generator client {
  provider = "prisma-client-js"
}

 datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum ProductType {
  STAMP_FILE
  EXTRACT_ONLY
  COMBO
}

model Project {
  id         String   @id @default(cuid())
  title      String?
  templateId String
  email      String?
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Order {
  id              String      @id @default(cuid())
  projectId       String?
  email           String
  productType     ProductType
  amount          Int
  currency        String      @default("USD")
  status          OrderStatus @default(PENDING)
  stripeSessionId String?     @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StampAsset {
  id          String   @id @default(cuid())
  name        String
  email       String?
  sourceType  String
  imagePath   String
  previewPath String?
  metaJson    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
